{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environmentName": {
      "value": "${AZURE_ENV_NAME}"
    },
    "location": {
      "value": "${AZURE_LOCATION}"
    },
    "clioRegion": {
      "value": "${CLIO_REGION=us}"
    },
    "logLevel": {
      "value": "${LOG_LEVEL=info}"
    },
    "auditMode": {
      "value": "${CLIO_AUDIT_MODE=metadata}"
    },
    "allowDestructive": {
      "value": "${CLIO_ALLOW_DESTRUCTIVE=false}"
    },
    "defaultUserId": {
      "value": "${CLIO_DEFAULT_USER_ID=}"
    },
    "imageTag": {
      "value": "${SERVICE_API_IMAGE_TAG=latest}"
    },
    "minReplicas": {
      "value": "${MIN_REPLICAS=1}"
    },
    "maxReplicas": {
      "value": "${MAX_REPLICAS=4}"
    }
  }
}
