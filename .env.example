# =============================================================================
# Clio MCP — environment template
# Copy to `.env` and fill in. Never commit `.env`.
# =============================================================================

# --- Clio OAuth (required) ---------------------------------------------------
# From Clio: Settings → Developer Applications → New Application
CLIO_CLIENT_ID=
CLIO_CLIENT_SECRET=

# --- Region (required) -------------------------------------------------------
# One of: us | ca | eu | au
CLIO_REGION=us

# --- Token encryption (required) ---------------------------------------------
# 64-char hex (32 bytes). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# In Azure deployments this is loaded from Key Vault via Managed Identity.
CLIO_ENCRYPTION_KEY=

# --- OAuth callback ----------------------------------------------------------
# Local: a loopback port for the OAuth flow.
# Must match the Redirect URI configured on your Clio Developer Application.
CLIO_REDIRECT_PORT=5678
CLIO_REDIRECT_HOST=127.0.0.1

# --- Transport ---------------------------------------------------------------
# stdio | http  (CLI flag --stdio or --http overrides this)
CLIO_TRANSPORT=stdio

# HTTP-only:
CLIO_HTTP_PORT=8765
CLIO_HTTP_HOST=0.0.0.0
# Comma-separated bearer tokens accepted by the HTTP transport.
# Leave empty for local dev. REQUIRED in production.
CLIO_HTTP_AUTH_TOKENS=

# --- Headless bootstrap ------------------------------------------------------
# For Azure / headless deployments only. Seed once with a refresh token obtained
# from a one-time local OAuth dance (see examples/bootstrap-refresh-token.mjs).
# On first boot the server uses this to mint an access token and write the
# encrypted token blob; subsequent restarts re-use the blob.
CLIO_BOOTSTRAP_REFRESH_TOKEN=

# --- State / storage ---------------------------------------------------------
# Where encrypted tokens and audit logs are written.
# Local default: ~/.clio-mcp/
# In containers, mount a volume here.
CLIO_STATE_DIR=

# --- Audit ------------------------------------------------------------------
# none | metadata | full   (metadata = no argument payloads; full = redacted args)
CLIO_AUDIT_MODE=metadata

# --- Behavior ----------------------------------------------------------------
# Allow destructive endpoints (DELETE). Default false.
CLIO_ALLOW_DESTRUCTIVE=false
# Default page size when listing.
CLIO_DEFAULT_PAGE_SIZE=25
# Max items a single tool call will return (caps pagination).
CLIO_MAX_PAGE_SIZE=200
# Optional default attorney/user id used for matter creation when caller omits it.
CLIO_DEFAULT_USER_ID=

# --- Logging -----------------------------------------------------------------
# error | warn | info | debug
LOG_LEVEL=info
