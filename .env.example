# =============================================================================
# Clio MCP — environment template
# Copy to `.env` and fill in. Never commit `.env`.
# =============================================================================

# --- Clio OAuth (required) ---------------------------------------------------
# From Clio: Settings → Developer Applications → New Application
CLIO_CLIENT_ID=
CLIO_CLIENT_SECRET=

# --- Region (required) -------------------------------------------------------
# One of: us | ca | eu | au
CLIO_REGION=us

# --- Token encryption (required) ---------------------------------------------
# 64-char hex (32 bytes). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# In Azure deployments this is loaded from Key Vault via Managed Identity.
CLIO_ENCRYPTION_KEY=

# --- OAuth callback / Redirect URIs ------------------------------------------
# Clio requires you to register a Redirect URI on the Developer Application.
# Register BOTH that you intend to use:
#
#   Local stdio (loopback flow): http://127.0.0.1:5678/callback
#                                (host:port from CLIO_REDIRECT_HOST/PORT below)
#   Remote connector (HTTP OAuth bridge): ${PUBLIC_BASE_URL}/oauth/clio/callback
#                                e.g. https://clio-mcp.example.com/oauth/clio/callback
#
# Clio allows multiple Redirect URIs per application — add both so the same
# Clio app works for local development and the production connector.
CLIO_REDIRECT_PORT=5678
CLIO_REDIRECT_HOST=127.0.0.1

# --- Transport ---------------------------------------------------------------
# stdio | http  (CLI flag --stdio or --http overrides this)
CLIO_TRANSPORT=stdio

# HTTP-only:
CLIO_HTTP_PORT=8765
CLIO_HTTP_HOST=0.0.0.0

# --- Remote connector / HTTP auth mode ---------------------------------------
# How the HTTP transport authenticates MCP clients:
#   oauth  : remote OAuth 2.1 custom-connector flow ONLY. Each end user signs in
#            to THEIR OWN Clio account. No shared account; CLIO_HTTP_AUTH_TOKENS
#            and CLIO_BOOTSTRAP_REFRESH_TOKEN are not used. Requires PUBLIC_BASE_URL.
#   static : legacy shared static bearer token(s) ONLY, mapped to a single shared
#            Clio account (disk blob / bootstrap refresh token). No PUBLIC_BASE_URL
#            needed.
#   hybrid : accept EITHER an OAuth-issued per-user session token OR a configured
#            static token (default). Requires PUBLIC_BASE_URL.
MCP_AUTH_MODE=hybrid

# Public, externally-reachable base URL of THIS server (no trailing slash).
# REQUIRED when MCP_AUTH_MODE is "oauth" or "hybrid": the OAuth Authorization
# Server metadata and the Clio redirect URI must be fixed absolute URLs. Must be
# https in production. The connector URL you paste into Claude is ${PUBLIC_BASE_URL}/mcp.
PUBLIC_BASE_URL=

# Lifetime of an issued MCP session (the connector access token) in seconds.
# Default 2592000 (30 days). Clio access tokens inside the session auto-refresh.
MCP_SESSION_TTL_SECONDS=2592000

# Optional space-separated Clio OAuth scopes appended to the Clio authorize URL.
# Leave empty to request Clio's default (full) access.
CLIO_OAUTH_SCOPES=

# Comma-separated bearer tokens accepted by the HTTP transport in static/hybrid
# mode (the shared-account path). Leave empty for local dev / pure-oauth mode.
# REQUIRED in production static mode.
CLIO_HTTP_AUTH_TOKENS=

# --- Headless bootstrap (static / shared mode only) --------------------------
# Seeds the SHARED Clio account for static/hybrid HTTP mode (and is irrelevant
# in pure "oauth" mode, where each user brings their own account). Obtain once
# from a local OAuth dance (see examples/bootstrap-refresh-token.mjs). On first
# boot the server mints an access token and writes the encrypted token blob;
# subsequent restarts re-use the blob.
CLIO_BOOTSTRAP_REFRESH_TOKEN=

# --- State / storage ---------------------------------------------------------
# Where encrypted tokens and audit logs are written.
# Local default: ~/.clio-mcp/
# In containers, mount a volume here.
CLIO_STATE_DIR=

# --- Audit ------------------------------------------------------------------
# none | metadata | full   (metadata = no argument payloads; full = redacted args)
CLIO_AUDIT_MODE=metadata

# --- Behavior ----------------------------------------------------------------
# Allow destructive endpoints (DELETE). Default false.
CLIO_ALLOW_DESTRUCTIVE=false
# Default page size when listing.
CLIO_DEFAULT_PAGE_SIZE=25
# Max items a single tool call will return (caps pagination).
CLIO_MAX_PAGE_SIZE=200
# Optional default attorney/user id used for matter creation when caller omits it.
CLIO_DEFAULT_USER_ID=

# --- Logging -----------------------------------------------------------------
# error | warn | info | debug
LOG_LEVEL=info
